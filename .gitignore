## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Vv]isualStudioTester/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the test results directory
#TestResults/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCop.Cache

# JetBrains Resharper
_ReSharper*/
*.[Rr]e[Ss]harper.user

# SQLite database
*.db
*.db-shm
*.db-wal

# OpenAI/Groq Keys (por seguridad)
# appsettings.json  <-- Comentado para permitir subida
appsettings.Development.json
