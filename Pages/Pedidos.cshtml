@page
@model PuestoWeb.Pages.PedidosModel
@{
    ViewData["Title"] = "Mis Pedidos";
}

<div class="container py-4">
    <h1 class="mb-4"><i class="bi bi-bag-check me-2 text-success"></i>Mi Historial de Pedidos</h1>

    @if (!Model.Pedidos.Any())
    {
        <div class="text-center py-5 bg-light rounded border shadow-sm">
            <i class="bi bi-receipt-cutoff display-1 text-muted"></i>
            <h2 class="mt-3">Aún no tienes pedidos</h2>
            <p class="text-muted">Cuando realices tu primera compra, aparecerá aquí.</p>
            <a asp-page="/Catalogo" class="btn btn-success mt-2">Ir al Catálogo</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var pedido in Model.Pedidos)
            {
                <div class="col">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                            <span class="fw-bold">Pedido #@pedido.Id</span>
                            <span class="badge @(pedido.Estado == Models.EstadoPedido.Pendiente ? "bg-warning text-dark" : "bg-info")">
                                @pedido.Estado
                            </span>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-3"><i class="bi bi-calendar3 me-2"></i>@pedido.FechaPedido.ToString("f")</p>
                            
                            <ul class="list-group list-group-flush mb-3">
                                @foreach (var linia in pedido.Linias)
                                {
                                    <li class="list-group-item px-0 bg-transparent d-flex justify-content-between">
                                        <span>@linia.Cantidad x @linia.Articulo.Nombre</span>
                                        <span class="text-muted">$@linia.Subtotal.ToString("N2")</span>
                                    </li>
                                }
                            </ul>
                            
                            <div class="d-flex justify-content-between align-items-center pt-2 border-top">
                                <span class="h5 mb-0 fw-bold text-success">Total: $@pedido.Total.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
