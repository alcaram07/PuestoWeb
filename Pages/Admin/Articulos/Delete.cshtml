@page "{id:int}"
@model PuestoWeb.Pages.Admin.Articulos.DeleteModel
@{
    ViewData["Title"] = "Eliminar Artículo";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h2 class="h5 mb-0">Eliminar Artículo</h2>
            </div>
            <div class="card-body">
                <p class="lead text-center">¿Estás seguro de que quieres eliminar este artículo?</p>
                
                <div class="d-flex align-items-center mb-4 p-3 bg-light rounded">
                    @if (!string.IsNullOrEmpty(Model.Articulo.ImagenUrl))
                    {
                        <img src="@Model.Articulo.ImagenUrl" alt="@Model.Articulo.Nombre" class="rounded me-3" style="width: 80px; height: 80px; object-fit: cover;">
                    }
                    <div>
                        <h3 class="h5 mb-1">@Model.Articulo.Nombre</h3>
                        <p class="mb-0 text-muted">@Model.Articulo.Tipo - $@Model.Articulo.Precio</p>
                    </div>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Articulo.Id" />
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
