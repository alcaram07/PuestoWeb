@page
@model PuestoWeb.Pages.Admin.Articulos.IndexModel
@{
    ViewData["Title"] = "Gestión de Artículos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-gear-fill me-2"></i>Gestión de Artículos</h1>
    <a asp-page="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>Nuevo Artículo
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Precio</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Articulos)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                {
                                    <img src="@item.ImagenUrl" alt="@item.Nombre" class="rounded me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light rounded me-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                                <div>
                                    <div class="fw-bold">@item.Nombre</div>
                                    <small class="text-muted text-truncate d-block" style="max-width: 200px;">@item.Descripcion</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge @(item.Tipo == Models.TipoArticulo.Fruta ? "bg-warning text-dark" : "bg-success")">
                                @item.Tipo
                            </span>
                        </td>
                        <td class="fw-bold text-success">
                            $@item.Precio.ToString("N2")
                        </td>
                        <td class="text-end">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
