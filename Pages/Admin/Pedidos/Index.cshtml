@page
@model PuestoWeb.Pages.Admin.Pedidos.IndexModel
@{
    ViewData["Title"] = "Gestión de Pedidos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-receipt me-2"></i>Pedidos Recibidos</h1>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Origen</th>
                    <th>Total</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Pedidos)
                {
                    <tr>
                        <td>#@item.Id</td>
                        <td>@item.FechaPedido.ToString("g")</td>
                        <td>
                            <div class="fw-bold">@item.Cliente.Nombre @item.Cliente.Apellido</div>
                            <small class="text-muted">@item.Cliente.Telefono</small>
                        </td>
                        <td>
                            @if (item.EsWhatsApp)
                            {
                                <span class="badge bg-success"><i class="bi bi-whatsapp me-1"></i>WhatsApp</span>
                            }
                            else
                            {
                                <span class="badge bg-primary"><i class="bi bi-globe me-1"></i>Web</span>
                            }
                        </td>
                        <td class="fw-bold">$@item.Total.ToString("N2")</td>
                        <td>
                            <span class="badge @(item.Estado == Models.EstadoPedido.Pendiente ? "bg-warning text-dark" : "bg-info")">
                                @item.Estado
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>Ver Detalle
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
