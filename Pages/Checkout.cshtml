@page
@model PuestoWeb.Pages.CheckoutModel
@{
    ViewData["Title"] = "Finalizar Pedido";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h2 class="h5 mb-0">Datos de Entrega</h2>
                </div>
                <div class="card-body">
                    <form method="post" id="checkoutForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Nombre" class="form-label">Nombre</label>
                                <input asp-for="Input.Nombre" class="form-control" />
                                <span asp-validation-for="Input.Nombre" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Input.Apellido" class="form-label">Apellido</label>
                                <input asp-for="Input.Apellido" class="form-control" />
                                <span asp-validation-for="Input.Apellido" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Direccion" class="form-label">Dirección de Entrega</label>
                            <input asp-for="Input.Direccion" class="form-control" placeholder="Calle, Número, Depto..." />
                            <span asp-validation-for="Input.Direccion" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Telefono" class="form-label">Teléfono de Contacto</label>
                            <input asp-for="Input.Telefono" class="form-control" placeholder="Ej: +54 9 11 ..." />
                            <span asp-validation-for="Input.Telefono" class="text-danger"></span>
                            <small class="text-muted">Lo usaremos para coordinar la entrega por WhatsApp.</small>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check2-circle me-2"></i>Confirmar Pedido
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm bg-light">
                <div class="card-body">
                    <h3 class="h5 mb-4">Resumen del Pedido</h3>
                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var item in Model.CartItems)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0">
                                <div>
                                    <h6 class="my-0">@item.Nombre</h6>
                                    <small class="text-muted">Cantidad: @item.Cantidad</small>
                                </div>
                                <span class="text-muted">$@item.Subtotal.ToString("N2")</span>
                            </li>
                        }
                        <li class="list-group-item d-flex justify-content-between bg-transparent px-0 fw-bold h5 mt-2">
                            <span>Total (ARS)</span>
                            <span class="text-success">$@Model.Total.ToString("N2")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
